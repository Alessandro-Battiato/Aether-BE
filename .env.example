# Server
PORT=3000
NODE_ENV=development

# PostgreSQL — e.g. postgresql://user:password@localhost:5432/gptclone
DATABASE_URL="postgresql://user:password@localhost:5432/gptclone"

# Used by Vitest integration tests (separate DB to keep test data isolated)
TEST_DATABASE_URL="postgresql://user:password@localhost:5432/gptclone_test"

# JWT
JWT_SECRET="change_me_to_a_long_random_string"
JWT_EXPIRES_IN="7d"

# OpenRouter  (https://openrouter.ai/keys)
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# CORS — URL of the React client
CLIENT_URL="http://localhost:5173"
